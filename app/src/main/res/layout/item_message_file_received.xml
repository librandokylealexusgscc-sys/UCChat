<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="64dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/imgAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/circle_grey_bg"
        android:scaleType="centerCrop"
        android:contentDescription="Avatar" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- File bubble -->
        <LinearLayout
            android:id="@+id/bubbleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bubble_received"
            android:clickable="true"
            android:focusable="true">

            <!-- Forwarded indicator — shown when message was forwarded -->
            <TextView
                android:id="@+id/tvForwardedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➦ Forwarded"
                android:textSize="11sp"
                android:textColor="#888888"
                android:fontFamily="@font/regular"
                android:paddingBottom="2dp"
                android:visibility="gone" />

            <!-- File row (icon + name + size) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <!-- File icon -->
                <TextView
                    android:id="@+id/tvFileIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄"
                    android:textSize="28sp"
                    android:layout_marginEnd="10dp" />

                <!-- File info -->
                <LinearLayout
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bold"
                        android:textColor="#000000"
                        android:textSize="13sp"
                        android:maxLines="2"
                        android:ellipsize="middle" />

                    <TextView
                        android:id="@+id/tvFileSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:paddingTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/regular"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:paddingTop="2dp" />

    </LinearLayout>

</LinearLayout>