<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:background="#FFFFFF">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="60.6dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/bold"
            android:gravity="start|center_vertical"
            android:text="UCChat"
            android:textColor="@android:color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnAdd"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/add"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add Button" />

    </LinearLayout>

    <!-- Tab Row: All | Group | Unread -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <!-- All Tab (selected) -->
        <TextView
            android:id="@+id/btnAllChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/tab_selected_bg"
            android:fontFamily="@font/bold"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="All"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Group Tab -->
        <TextView
            android:id="@+id/btnGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/tab_unselected_bg"
            android:fontFamily="@font/regular"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Group"
            android:textColor="#888888"
            android:textSize="13sp" />

        <!-- Unread Tab -->
        <TextView
            android:id="@+id/btnUnread"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/tab_unselected_bg"
            android:fontFamily="@font/regular"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Unread"
            android:textColor="#888888"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Content area: wraps both empty state and RecyclerView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- =============================================
             EMPTY STATE VIEW
             Visibility: VISIBLE when chat list is empty
                         GONE    when there are chats
             Control in Java/Kotlin:
               emptyStateLayout.visibility = View.VISIBLE / View.GONE
             ============================================= -->
        <LinearLayout
            android:id="@+id/emptyStateLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:visibility="visible">

            <!-- Waiting illustration -->
            <ImageView
                android:id="@+id/imgWaiting"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/waiting"
                android:scaleType="fitCenter"
                android:contentDescription="No chats yet illustration" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/bold"
                android:text="Waiting... ( ͡~ ͜ʖ ͡°)"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/regular"
                android:text="Looks like your inbox is empty. Start a \nnew conversation with a Yusisita now by \ntapping the button below."
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1" />

            <!-- Start New Chat Button -->
            <TextView
                android:id="@+id/btnStartNewChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/btn_start_new_chat"
                android:fontFamily="@font/regular"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="+ Start New Chat"
                android:textColor="#000000"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- =============================================
             CHAT LIST (RecyclerView)
             Visibility: GONE    when chat list is empty
                         VISIBLE when there are chats
             Control in Java/Kotlin:
               recyclerViewChats.visibility = View.VISIBLE / View.GONE
             ============================================= -->
        <!-- CHAT LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewChats"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:visibility="gone" />


    </FrameLayout>

    <!-- Divider above bottom nav -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD" />

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="22dp"
        android:orientation="horizontal"
        android:background="#FBFBFB">

        <LinearLayout
            android:id="@+id/btnTabChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/chatgreen"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Chats Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Chats"
                android:textColor="#4CAF50"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/searchstudent"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Search Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Search"
                android:textColor="#999999"
                android:textSize="11sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabMenu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/menu"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Menu Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Menu"
                android:textColor="#999999"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>