<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup__background">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bold"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:text="Send Attachment"
        android:textColor="@color/text_primary"
        android:textSize="17sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C8C8CC" />

    <!-- Image Option -->
    <TextView
        android:id="@+id/btnAttachImage"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:fontFamily="@font/regular"
        android:gravity="center"
        android:text="📷  Image"
        android:textColor="#4CAF50"
        android:textSize="17sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C8C8CC" />

    <!-- Video Option -->
    <TextView
        android:id="@+id/btnAttachVideo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:fontFamily="@font/regular"
        android:gravity="center"
        android:text="🎥  Video"
        android:textColor="#4CAF50"
        android:textSize="17sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C8C8CC" />

    <!-- File Option -->
    <TextView
        android:id="@+id/btnAttachFile"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:fontFamily="@font/regular"
        android:gravity="center"
        android:text="📎  File"
        android:textColor="#4CAF50"
        android:textSize="17sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C8C8CC" />

    <!-- Cancel -->
    <TextView
        android:id="@+id/btnAttachCancel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:fontFamily="@font/bold"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="#4CAF50"
        android:textSize="17sp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>