<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="24dp">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left"
                    android:layout_marginLeft="23dp"
                    android:layout_marginTop="18dp"
                    android:scaleType="centerCrop"

                    android:src="@drawable/back" />

                <ImageView
                    android:id="@+id/imgProfileInfo"
                    android:layout_width="133dp"
                    android:layout_height="137dp"
                    android:background="@drawable/circle_grey_bg"
                    android:layout_marginTop="0dp"
                    android:contentDescription="Profile photo"
                    android:padding="18dp"
                    android:scaleType="center"
                    app:tint="#AAAAAA" />

                <!-- Name -->
                <TextView
                    android:id="@+id/studentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/bold"
                    android:text="Eli Jarder"
                    android:textColor="#000000"
                    android:textSize="34sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Action Buttons Row: Mute | Search -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingBottom="32dp">

                <!-- Mute Button -->
                <LinearLayout
                    android:id="@+id/btnMute"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_btn_bg"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/mute"
                        android:scaleType="fitCenter"
                        app:tint="#4CAF50"
                        android:contentDescription="Mute" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/regular"
                        android:text="Mute"
                        android:textColor="#000000"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Search Button -->
                <LinearLayout
                    android:id="@+id/btnSearchChat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/action_btn_bg"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/searchchat"
                        android:scaleType="fitCenter"
                        app:tint="#4CAF50"
                        android:contentDescription="Search" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/regular"
                        android:text="Search"
                        android:textColor="#000000"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Bottom Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- Clear Chat -->
                <LinearLayout
                    android:id="@+id/btnClearChat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/deleteconvo"
                        android:scaleType="centerCrop"
                        app:tint="#4CAF50"
                        android:contentDescription="Clear Chat" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:fontFamily="@font/regular"
                        android:text="Delete Conversation"
                        android:textColor="#000000"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- Block -->
                <LinearLayout
                    android:id="@+id/btnBlock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/block"
                        android:scaleType="centerCrop"
                        app:tint="#E53935"
                        android:contentDescription="Block" />

                    <TextView
                        android:id="@+id/tvBlockLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:fontFamily="@font/regular"
                        android:text="Block Eli"
                        android:textColor="#E53935"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    <!-- SEARCH CHAT OVERLAY -->
    <!-- SEARCH CHAT OVERLAY -->
    <FrameLayout
        android:id="@+id/searchOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#ffffffff"
        android:paddingTop="35dp"
        android:visibility="gone"
        tools:visibility="gone">

        <!-- TOP SEARCH BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:id="@+id/searchBackBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"

                android:paddingTop="7dp"
                android:paddingRight="15dp"
                android:scaleType="centerCrop"


                android:src="@drawable/back" />

            <EditText
                android:id="@+id/searchChatInput"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/input_rounded_bg"
                android:fontFamily="@font/medium"
                android:hint="Search messages..."
                app:hintTextColor="#BBBBBB"
                android:paddingStart="12dp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- EMPTY STATE -->
        <TextView
            android:id="@+id/searchEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0.7"
            android:fontFamily="@font/medium"
            android:text="Search messages"
            android:textColor="#120C0C"
            android:textSize="18sp" />

        <!-- SCROLLABLE RESULTS -->
        <ScrollView
            android:id="@+id/searchScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="70dp"
            android:visibility="gone"
            tools:visibility="gone">

            <LinearLayout
                android:id="@+id/searchResultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- RESULT ITEM -->
                <LinearLayout
                    android:id="@+id/searchResultItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:background="#FFFFFF"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/resultProfile"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/circle_grey_bg"
                        android:padding="6dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- NAME + TIME -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/resultName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/bold"
                                android:text="Shimenet"
                                android:textColor="#000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/datetime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/regular"
                                android:text="5:00 pm"
                                android:textColor="#888"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- MESSAGE -->
                        <TextView
                            android:id="@+id/resultMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/regular"
                            android:text="Eli: Beh nomiii"
                            android:textColor="#666"
                            android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- CENTER CONFIRM POPUP -->
    <LinearLayout
        android:id="@+id/centerConfirmPopup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/popup_background"
        android:elevation="10dp"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="gone">

        <!-- MESSAGE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bold"
            android:gravity="center"
            android:padding="20dp"
            android:text="Do you want to do this?"
            android:textColor="#000000"
            android:textSize="16sp"
            tools:visibility="visible" />


        <!-- HORIZONTAL DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD" />


        <!-- BUTTON ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:weightSum="2">


            <!-- CANCEL BUTTON -->
            <TextView
                android:id="@+id/popupCancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/medium"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="Cancel"
                android:textColor="#4CAF50"
                android:textSize="15sp" />


            <!-- VERTICAL DIVIDER -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#DDDDDD" />


            <!-- OK BUTTON -->
            <TextView
                android:id="@+id/popupOK"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/medium"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="OK"
                android:textColor="#4CAF50"
                android:textSize="15sp" />

        </LinearLayout>


    </LinearLayout>



</FrameLayout>