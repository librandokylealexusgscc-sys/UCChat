<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:layout_marginTop="19dp"
    android:background="#FFFFFF">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:layout_marginTop="28.9dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/bold"
            android:gravity="start|center_vertical"
            android:text="UCChat"
            android:textColor="@android:color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnAdd"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/add"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add Button" />
    </LinearLayout>

    <!-- Tab Row: All | Group | Unread -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <!-- All Tab -->
        <TextView
            android:id="@+id/btnAllChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/regular"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="All"
            android:textColor="#888888"
            android:textSize="13sp" />

        <!-- Group Tab -->
        <TextView
            android:id="@+id/btnGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/regular"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Group"
            android:textColor="#888888"
            android:textSize="13sp" />

        <!-- Unread Tab (selected) -->
        <TextView
            android:id="@+id/btnUnread"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/tab_selected_bg"
            android:fontFamily="@font/bold"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Unread"
            android:textColor="#000000"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="76dp" />

    <!-- Content Area: FrameLayout to stack empty state + scroll view -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- =============================================
             EMPTY STATE VIEW
             VISIBLE when unread list is empty
             GONE    when there are unread chats
             ============================================= -->
        <LinearLayout
            android:id="@+id/emptyUnreadStateLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:visibility="visible"
            tools:visibility="visible">

            <!-- No Unread Illustration -->
            <ImageView
                android:layout_width="260dp"
                android:layout_height="220dp"
                android:src="@drawable/nounread"
                android:scaleType="fitCenter"
                android:contentDescription="No unread messages illustration" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/bold"
                android:text="Wow, no unread messages&#10;(͡~ ͜ ͡°)"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/regular"
                android:text="You're that one friend who takes time to \nread messages even from a yapper one."
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1" />

        </LinearLayout>

        <!-- =============================================
             CHAT LIST (ScrollView)
             GONE    when unread list is empty
             VISIBLE when there are unread chats
             tools:visibility="visible" lets you edit in Design view
             ============================================= -->
        <ScrollView
            android:id="@+id/scrollViewChats"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="visible"
            tools:visibility="gone">

            <LinearLayout
                android:id="@+id/ChatItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Chat Item: Shimenet -->
                <LinearLayout
                    android:id="@+id/chat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <!-- Avatar -->
                    <ImageView
                        android:id="@+id/ImgProfile"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_grey_bg"
                        android:contentDescription="Shimenet avatar"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="#AAAAAA" />

                    <!-- Name + Preview -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:id="@+id/studentName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/bold"
                            android:text="Shimenet"
                            android:textColor="#000000"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/message"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/regular"
                            android:paddingTop="2dp"
                            android:text="Eli: Beh nomiii"
                            android:textColor="#888888"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Timestamp -->
                    <TextView
                        android:id="@+id/timestamp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:fontFamily="@font/regular"
                        android:text="5:00 pm"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Divider under chat item -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="76dp"
                    android:background="#F0F0F0" />

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD" />

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:layout_marginBottom="22dp"
        android:background="#FBFBFB">

        <LinearLayout
            android:id="@+id/btnTabChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/chatgreen"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Chats Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Chats"
                android:textColor="#4CAF50"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/searchstudent"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Search Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Search"
                android:textColor="#999999"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabMenu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/menu"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Menu Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Menu"
                android:textColor="#999999"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>