<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="64dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/tvDateSeparator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:fontFamily="@font/regular"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/imgAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/circle_grey_bg"
        android:scaleType="centerCrop"
        android:contentDescription="Avatar" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/bubbleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <TextView
                android:id="@+id/tvForwardedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➦ Forwarded"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/regular"
                android:paddingBottom="2dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/replyPreviewBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1A4CAF50"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="#4CAF50"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvReplySender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You"
                        android:textColor="#4CAF50"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvReplyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Original message..."
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bubble_received"
                android:maxWidth="220dp"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:fontFamily="@font/regular"
                android:textColor="@color/bubble_received_text"
                android:textSize="14sp"
                android:autoLink="web"
                android:linksClickable="true"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/imgMessage"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:contentDescription="Image message"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/regular"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:paddingTop="2dp" />
    </LinearLayout>
</LinearLayout>