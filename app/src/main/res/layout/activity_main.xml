<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:background="@android:color/white"
    tools:context=".MainActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:layout_marginTop="49dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/bold"
            android:gravity="start|center_vertical"
            android:text="UCChat"
            android:textColor="@android:color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnAdd"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/add"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add Button" />
    </LinearLayout>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/SearchStudent"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="1dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/search_bar_background"
        android:fontFamily="@font/regular"
        android:hint="Search"
        android:inputType="text"
        android:maxLines="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@android:color/black"
        android:textColorHint="#999999"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD" />

    <!-- FrameLayout: stacks all 3 states -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- =============================================
             STATE 1: EMPTY SEARCH BAR
             VISIBLE when search bar is empty (default)
             GONE    when user is typing
             ============================================= -->
        <LinearLayout
            android:id="@+id/emptySearchLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="visible"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/imageViewSearching"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginBottom="32dp"
                android:contentDescription="Searching illustration"
                android:scaleType="centerInside"
                android:src="@drawable/searching" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-30dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/bold"
                android:gravity="center"
                android:text="Search a Yusisista (눈_눈)"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:gravity="center"
                android:lineSpacingMultiplier="1.1"
                android:text="Make friends with any Yusisistas! Make\nsure to make this space a safe abode!"
                android:textColor="#757575"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- =============================================
             STATE 2: SEARCH NOT FOUND
             VISIBLE when search returns no results
             GONE    otherwise
             ============================================= -->
        <LinearLayout
            android:id="@+id/notFoundLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
            tools:visibility="gone">

            <ImageView
                android:layout_width="220dp"
                android:layout_height="200dp"
                android:layout_marginBottom="24dp"
                android:contentDescription="No results found illustration"
                android:scaleType="fitCenter"
                android:src="@drawable/studentnotfound" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/bold"
                android:gravity="center"
                android:text="Oops (crickets)..."
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:gravity="center"
                android:lineSpacingMultiplier="1"
                android:text="Make sure you typed their correct \nStudent ID or name and try again!"
                android:textColor="#757575"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- =============================================
             STATE 3: SEARCH RESULTS
             VISIBLE when results are found
             GONE    otherwise
             ============================================= -->
        <ScrollView
            android:id="@+id/searchResultsScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="gone"
            tools:visibility="gone">

            <LinearLayout
                android:id="@+id/searchResultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Sample Result Item (replicated dynamically in Java) -->
                <LinearLayout
                    android:id="@+id/chatItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:id="@+id/ImgProfile"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/circle_grey_bg"
                        android:contentDescription="Student avatar"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/studentName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/regular"
                        android:text="Eli Jarder"
                        android:textColor="#000000"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD" />

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="22dp"
        android:orientation="horizontal"
        android:background="#FBFBFB">

        <LinearLayout
            android:id="@+id/btnTabChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/chat"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Chats Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Chats"
                android:textColor="#999999"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/searchstudent"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Search Icon"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Search"
                android:textColor="#4CAF50"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabMenu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/menu"
                android:scaleType="centerCrop"
                android:layout_marginBottom="2dp"
                android:contentDescription="Menu Icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:text="Menu"
                android:textColor="#999999"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>