<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:orientation="vertical"
        tools:visibility="visible">
        <!-- Top App Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="45dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- Back Arrow -->
            <!-- Avatar -->
            <ImageView
                android:id="@+id/viewImagebackBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginLeft="15dp"
                android:paddingTop="7dp"
                android:paddingRight="15dp"
                android:scaleType="centerCrop"


                android:src="@drawable/back" />

            <ImageView
                android:id="@+id/ImgProfile"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="50dp"
                android:background="@drawable/circle_grey_bg"
                android:contentDescription="Contact avatar" />

            <!-- Name + Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/studentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shimenet"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- Content Area: FrameLayout to stack empty state + message scroll -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:visibility="visible">

            <!-- =============================================
             EMPTY STATE — First conversation
             VISIBLE when no messages yet
             GONE    when messages exist
             ============================================= -->
            <LinearLayout
                android:id="@+id/emptyConversationLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F7F7F7"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="visible"
                tools:visibility="visible">

                <!-- Start Chat Illustration -->
                <ImageView
                    android:layout_width="240dp"
                    android:layout_height="220dp"
                    android:contentDescription="Start a conversation illustration"
                    android:scaleType="fitCenter"
                    android:src="@drawable/startchat" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Come on, make the first move!&#10;(͡~ ͜ ͡°)"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1"
                    android:text="Begin the amazing conversation \nwith each other!"
                    android:textColor="#888888"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- =============================================
             SCROLLABLE MESSAGE AREA
             GONE    when no messages yet
             VISIBLE when messages exist
             tools:visibility="visible" to edit in Design view
             ============================================= -->
            <ScrollView
                android:id="@+id/scrollViewMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F7F7F7"
                android:fillViewport="true"
                android:scrollbars="none"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    tools:visibility="visible">

                    <!-- Date Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:paddingTop="4dp"
                        android:paddingBottom="12dp"
                        android:text="Today"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />

                    <!-- Received Message Bubble -->
                    <LinearLayout
                        android:id="@+id/chatItemReceiver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="start"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/circle_grey_bg"
                            android:contentDescription="avatar" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bubble_received"
                                android:maxWidth="220dp"
                                android:paddingStart="12dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="8dp"
                                android:text="Hey! How are you?"
                                android:textColor="#000000"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingTop="4dp"
                                android:text="5:00 pm"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Sent Message Bubble -->
                    <LinearLayout
                        android:id="@+id/chatItemSender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bubble_sent"
                                android:maxWidth="220dp"
                                android:paddingStart="12dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="8dp"
                                android:text="I'm good, thanks!"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingTop="4dp"
                                android:text="5:01 pm"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/messageStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingTop="4dp"
                                android:text="Seen"
                                android:textAlignment="textEnd"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

        </FrameLayout>


        <!-- Divider above input -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- Bottom Input Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="40dp"
            tools:visibility="visible">


            <!-- File / Attach Button -->
            <ImageView
                android:id="@+id/SendFile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="Attach file"
                android:src="@drawable/filesend" />

            <!-- Message EditText -->
            <EditText
                android:id="@+id/etTypingBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/input_bg"
                android:hint="Type a message..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp"
                android:textColor="#000000"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp" />

            <!-- Send Button -->
            <ImageView
                android:id="@+id/SendMessage"
                android:layout_width="38dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Send message"
                android:src="@drawable/send" />

        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/popup_afterlongpress"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/popup_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"

        android:padding="12dp"

        android:visibility="gone"
        tools:visibility="gone">

        <!-- Reply -->
        <LinearLayout
            android:id="@+id/btnReply"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/reply"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reply"
                android:textColor="#4CAF50"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Copy -->
        <LinearLayout
            android:id="@+id/btnCopy"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/copy"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy"
                android:textColor="#4CAF50"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Forward -->
        <LinearLayout
            android:id="@+id/btnForwardViewImage"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="visible"
            tools:visibility="gone">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/forward"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forward"
                android:textColor="#4CAF50"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Delete -->
        <LinearLayout
            android:id="@+id/btnDelete"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/delete"
                app:tint="#4CAF50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete"
                android:textColor="#4CAF50"
                android:textSize="12sp" />
        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/viewImageLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:visibility="gone">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <!-- Back Button -->
            <!-- Avatar -->
            <ImageView
                android:id="@+id/backBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginLeft="15dp"
                android:paddingTop="7dp"
                android:paddingRight="15dp"
                android:scaleType="centerCrop"


                android:src="@drawable/back" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Save / Download Button -->
            <ImageView
                android:id="@+id/btnSaveDoc"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:clickable="true"
                android:contentDescription="Save"
                android:focusable="true"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/savedoc" />

            <!-- Forward Button -->
            <ImageView
                android:id="@+id/btnForward"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:clickable="true"
                android:contentDescription="Forward"
                android:focusable="true"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/forward" />

        </LinearLayout>

        <!-- Full-Screen Image Viewer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgViewFull"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="Full screen image"
                android:scaleType="fitCenter" />

        </LinearLayout>

    </LinearLayout>







</FrameLayout>