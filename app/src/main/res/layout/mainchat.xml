<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_main"
        android:orientation="vertical"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="45dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/btnviewImageback"
                app:tint="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginLeft="15dp"
                android:paddingTop="7dp"
                android:paddingRight="15dp"
                android:scaleType="centerCrop"
                android:src="@drawable/back" />

            <ImageView
                android:id="@+id/ImgProfile"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="50dp"
                android:background="@drawable/circle_grey_bg"
                android:contentDescription="Contact avatar" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/studentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:id="@+id/onlineDot"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/circle_green_bg"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:textColor="#4CAF50"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvProgramId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color" />

        <FrameLayout
            android:id="@+id/messageContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:visibility="visible">

            <LinearLayout
                android:id="@+id/emptyConversationLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg_main"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="visible"
                tools:visibility="visible">
                <ImageView
                    android:layout_width="240dp"
                    android:layout_height="220dp"
                    android:contentDescription="Start a conversation illustration"
                    android:scaleType="fitCenter"
                    android:src="@drawable/startchat" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Come on, make the first move!&#10;(͡~ ͜ ͡°)"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1"
                    android:text="Begin the amazing conversation \nwith each other!"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/scrollViewMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg_secondary"
                android:fillViewport="true"
                android:scrollbars="none"
                android:visibility="gone"
                tools:visibility="visible">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    tools:visibility="visible" />
            </ScrollView>
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_color" />

        <include layout="@layout/layout_reply_bar" />

        <!-- ✅ Blocked Banner — shown when either user blocked the other -->
        <TextView
            android:id="@+id/tvBlockedBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:textSize="13sp"
            android:fontFamily="@font/regular"
            android:textColor="#FFFFFF"
            android:background="#CC333333"
            android:visibility="gone" />

        <!-- ✅ Input bar — hidden when blocked -->
        <LinearLayout
            android:id="@+id/inputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="40dp"
            tools:visibility="visible">
            <ImageView
                android:id="@+id/SendFile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="Attach file"
                android:src="@drawable/filesend"
                app:tint="@color/text_primary"/>
            <EditText
                android:id="@+id/etTypingBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/input_bg"
                android:hint="Type a message..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:fontFamily="@font/regular"/>
            <ImageView
                android:id="@+id/SendMessage"
                android:layout_width="38dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Send message"
                android:src="@drawable/send"
                app:tint="@color/text_primary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Full Screen Image Viewer -->
    <LinearLayout
        android:id="@+id/viewImageLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">
            <ImageView
                android:id="@+id/imgViewBackBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingTop="7dp"
                android:paddingEnd="15dp"
                android:scaleType="centerCrop"
                android:src="@drawable/back"
                android:contentDescription="Back"
                app:tint="#FFFFFF" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <ImageView
                android:id="@+id/btnSaveDoc"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:clickable="true"
                android:contentDescription="Save"
                android:focusable="true"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/savedoc"
                app:tint="#FFFFFF" />
            <ImageView
                android:id="@+id/btnForwardViewImage"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:clickable="true"
                android:contentDescription="Forward"
                android:focusable="true"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/forward"
                app:tint="#FFFFFF" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/imgViewFull"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="Full screen image"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>