<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:orientation="vertical"
        tools:visibility="visible">

        <!-- Top App Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="45dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/btnviewImageback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginLeft="15dp"
                android:paddingTop="7dp"
                android:paddingRight="15dp"
                android:scaleType="centerCrop"
                android:src="@drawable/back" />

            <ImageView
                android:id="@+id/ImgProfile"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:layout_marginLeft="50dp"
                android:background="@drawable/circle_grey_bg"
                android:contentDescription="Contact avatar" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/studentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/onlineDot"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@drawable/circle_green_bg"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/regular"
                        android:textColor="#4CAF50"
                        android:textSize="12sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvProgramId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/regular"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- Content Area (messages) -->
        <FrameLayout
            android:id="@+id/messageContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:visibility="visible">

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyConversationLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F7F7F7"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="visible"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="240dp"
                    android:layout_height="220dp"
                    android:contentDescription="Start a conversation illustration"
                    android:scaleType="fitCenter"
                    android:src="@drawable/startchat" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Come on, make the first move!&#10;(͡~ ͜ ͡°)"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1"
                    android:text="Begin the amazing conversation \nwith each other!"
                    android:textColor="#888888"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Scrollable Message Area (replaced by RecyclerView in Java) -->
            <ScrollView
                android:id="@+id/scrollViewMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F7F7F7"
                android:fillViewport="true"
                android:scrollbars="none"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    tools:visibility="visible" />

            </ScrollView>

        </FrameLayout>

        <!-- Divider above input -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- ✅ Reply Bar — sits just above the input, GONE by default -->
        <include layout="@layout/layout_reply_bar" />

        <!-- Bottom Input Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="40dp"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/SendFile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="Attach file"
                android:src="@drawable/filesend" />

            <EditText
                android:id="@+id/etTypingBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/input_bg"
                android:hint="Type a message..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp"
                android:textColor="#000000"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/SendMessage"
                android:layout_width="38dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Send message"
                android:src="@drawable/send" />

        </LinearLayout>

    </LinearLayout>

    <!-- Full Screen Image Viewer -->
    <LinearLayout
        android:id="@+id/viewImageLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/imgViewBackBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingTop="7dp"
                android:paddingEnd="15dp"
                android:scaleType="centerCrop"
                android:src="@drawable/back"
                android:contentDescription="Back"
                app:tint="#FFFFFF" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btnSaveDoc"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:clickable="true"
                android:contentDescription="Save"
                android:focusable="true"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/savedoc"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/btnForwardViewImage"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:clickable="true"
                android:contentDescription="Forward"
                android:focusable="true"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@drawable/forward"
                app:tint="#FFFFFF" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgViewFull"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="Full screen image"
                android:scaleType="fitCenter" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>